rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getMyUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getMyUser().data.role == 'admin';
    }

    function isValidUserDoc(data) {
      return data.keys().hasOnly([
        'name', 'email', 'role', 'progress', 'theoryAccess', 'lessons',
        'hasNewLesson', 'hasNewHomework', 'grade', 'subject', 'avatar',
        'lessonsLeft', 'registeredAt'
      ])
      && data.name is string
      && data.email is string
      && data.role in ['student', 'admin']
      && data.progress is int
      && data.progress >= 0
      && data.progress <= 100
      && data.theoryAccess is bool
      && data.lessons is list
      && data.hasNewLesson is bool
      && data.hasNewHomework is bool
      && data.grade is string
      && data.subject is string
      && data.avatar is string
      && data.lessonsLeft is int
      && data.lessonsLeft >= 0
      && data.registeredAt is string;
    }

    function isValidStudentCreate(data) {
      return isValidUserDoc(data)
        && data.role == 'student'
        && data.theoryAccess == false
        && data.progress == 0
        && data.lessons.size() == 0
        && data.hasNewLesson == false
        && data.hasNewHomework == false
        && data.lessonsLeft == 0;
    }

    function isStudentUpdateAllowed() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.theoryAccess == resource.data.theoryAccess
        && request.resource.data.progress == resource.data.progress
        && request.resource.data.lessons == resource.data.lessons
        && request.resource.data.hasNewLesson == resource.data.hasNewLesson
        && request.resource.data.hasNewHomework == resource.data.hasNewHomework
        && request.resource.data.lessonsLeft == resource.data.lessonsLeft
        && request.resource.data.email == resource.data.email
        && request.resource.data.registeredAt == resource.data.registeredAt
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'role', 'progress', 'theoryAccess', 'lessons',
          'hasNewLesson', 'hasNewHomework', 'grade', 'subject', 'avatar',
          'lessonsLeft', 'registeredAt'
        ]);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isValidStudentCreate(request.resource.data);

      allow update: if isAdmin()
        || (isAuthenticated()
            && request.auth.uid == userId
            && isStudentUpdateAllowed());

      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
